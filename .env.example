# ══════════════════════════════════════════════
#   Orbit Station — Environment Variables
#   Copy this file to .env and fill in values.
#   NEVER commit the actual .env to version control.
# ══════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────
# Prisma Postgres connection string (sslmode=require for production)
DATABASE_URL=

# ── AUTH (NextAuth v5) ────────────────────────
# Generate a secret: openssl rand -hex 32
AUTH_SECRET=

# The canonical URL of your deployed app (required in production for JWT issuer & callbacks)
# Example: https://orbitstation.yourdomain.com
NEXTAUTH_URL=

# Same URL — used inside app code (metadata, email links, etc.)
NEXT_PUBLIC_APP_URL=

AUTH_TRUST_HOST=true

# ── OAUTH PROVIDERS ───────────────────────────
# GitHub OAuth App → https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth App → https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── EMAIL (Resend) ────────────────────────────
# Required for email verification and transactional mail
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=

# ── PUSHER (Real-time) ────────────────────────
# Create an app at: https://dashboard.pusher.com/
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ── SPECIAL BADGES (Internal) ─────────────────
# Comma-separated emails that get the creator badge
CREATOR_EMAILS=
# Comma-separated usernames that get the assistant badge
ASSISTANT_USERNAMES=