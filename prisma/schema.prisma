// This is your Prisma schema file for Orbit Station
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH MODELS (NextAuth.js v5 compatible)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CORE MODELS
// ============================================================

/// Pengguna / "Pilot" di Orbit Station
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Kustomisasi Profil
  bio           String?
  bannerUrl     String?
  titleBadge    String?   // e.g. "Pioneer Pilot", "Star Navigator"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts Account[]
  sessions Session[]
  station  Station?
}

/// Dasbor utama milik Pilot, disebut "Station"
model Station {
  id          String  @id @default(cuid())
  userId      String  @unique
  isPublic    Boolean @default(false)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectors Sector[]
}

/// Kelompok/kategori Beacon, disebut "Sektor"
model Sector {
  id        String  @id @default(cuid())
  stationId String
  name      String
  icon      String? // Emoji atau nama ikon
  color     String? // Accent color untuk sektor ini (hex)
  order     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  station Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  beacons Beacon[]
}

/// Shortcut web, disebut "Suar" (Beacon)
model Beacon {
  id          String  @id @default(cuid())
  sectorId    String
  url         String
  title       String
  description String?
  imageUrl    String? // OG Image yang di-scrape otomatis
  faviconUrl  String?
  notes       String? // Catatan pribadi pengguna
  isPinned    Boolean @default(false) // Ditampilkan di profil publik
  order       Int     @default(0)
  visitCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sector Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)
}
