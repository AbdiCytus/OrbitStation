// This is your Prisma schema file for Orbit Station
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH MODELS (NextAuth.js v5 compatible)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CORE MODELS
// ============================================================

/// Pengguna / "Pilot" di Orbit Station
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Kustomisasi Profil
  bio           String?
  bannerUrl     String?
  titleBadge    String?   // e.g. "Pioneer Pilot", "Star Navigator"
  callsign      String?   // Nama panggilan pengguna (ganti "Pilot")

  // Preferensi
  animationEnabled Boolean @default(false)
  hologramEnabled  Boolean @default(true)
  allowFriendRequests Boolean @default(true)
  staticBackgroundEnabled Boolean @default(false)

  // Email/password login (opsional, untuk akun Orbit Station)
  password      String?   // hashed, null = OAuth-only user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  station          Station?
  sentRequests     Friendship[]  @relation("SentRequests")
  receivedRequests Friendship[]  @relation("ReceivedRequests")
  sentMessages     ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")
  collabSectors    SectorCollaborator[] @relation("CollabSectors")
  createdBeacons   Beacon[]
  visitedStations  StationVisit[] @relation("UserVisits")
  sentGroupMessages GroupMessage[] @relation("SentGroupMessages")
  mutedInSectors   MutedMember[]  @relation("MutedUsers")
  notifSoundUrl    String?        // Custom SFX URL
  notifSoundEnabled Boolean       @default(true)
  shortcuts        String?        @default("{\"publicStation\":\"F1\",\"friends\":\"F2\",\"analytics\":\"F3\",\"settings\":\"F4\"}")
  typingIndicators TypingIndicator[]
  blindedInSectors BlindedMember[] @relation("BlindedUsers")
  ownedOAuthApps   OAuthApp[]      @relation("OwnedApps")
}

/// Dasbor utama milik Pilot, disebut "Station"
model Station {
  id          String  @id @default(cuid())
  userId      String  @unique
  isPublic    Boolean @default(false)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectors Sector[]
  visits  StationVisit[]
}

model StationVisit {
  id        String   @id @default(cuid())
  stationId String
  visitorId String?
  createdAt DateTime @default(now())

  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  visitor   User?    @relation("UserVisits", fields: [visitorId], references: [id], onDelete: SetNull)
}

/// Kelompok/kategori Beacon, disebut "Sektor"
model Sector {
  id        String  @id @default(cuid())
  stationId String
  name      String
  icon      String? // Emoji atau nama ikon
  color     String? // Accent color untuk sektor ini (hex)
  order     Int     @default(0)
  isPublic  Boolean @default(true) // false = sektor privat, tidak ditampilkan di profil publik
  isMuteAll Boolean @default(false)
  inviteEnabled Boolean @default(false)
  pinnedMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  station Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  beacons Beacon[]
  collaborators SectorCollaborator[]
  groupMessages GroupMessage[]
  mutedMembers  MutedMember[]
  typingIndicators TypingIndicator[]
  blindedMembers BlindedMember[]
  invites        SectorInvite[]
}

/// Shortcut web, disebut "Suar" (Beacon)
model Beacon {
  id          String   @id @default(cuid())
  sectorId    String
  url         String
  title       String
  description String?
  imageUrl    String?
  faviconUrl  String?
  notes       String?
  isPinned    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sector      Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  creatorId   String?
  creator     User?    @relation(fields: [creatorId], references: [id])
  visits      Int      @default(0)
}

// ============================================================
// SOCIAL MODELS
// ============================================================

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  receiverId  String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  type       String   @default("TEXT") // TEXT, COLLAB_INVITE, COLLAB_ACCEPTED, COLLAB_REJECTED
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())
  
  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model SectorCollaborator {
  id        String   @id @default(cuid())
  sectorId  String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user      User     @relation("CollabSectors", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectorId, userId])
}

model SectorInvite {
  id        String   @id @default(cuid())
  sectorId  String
  token     String   @unique
  expiresAt DateTime?
  maxUses   Int?
  uses      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
}

// ============================================================
// GROUP CHAT MODELS
// ============================================================

model GroupMessage {
  id        String   @id @default(cuid())
  sectorId  String
  senderId  String
  content   String
  type      String   @default("TEXT") // TEXT, SYSTEM
  replyToId String?
  isDeleted Boolean  @default(false)
  deletedBy String?  // userId who deleted (for owner-deleted messages)
  editedAt  DateTime?
  createdAt DateTime @default(now())

  sector    Sector         @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  sender    User           @relation("SentGroupMessages", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo   GroupMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   GroupMessage[] @relation("MessageReplies")

  @@index([sectorId, createdAt])
}

model MutedMember {
  id       String   @id @default(cuid())
  sectorId String
  userId   String
  mutedAt  DateTime @default(now())

  sector   Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user     User     @relation("MutedUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectorId, userId])
}

/// Typing indicator untuk group chat dan private chat
model TypingIndicator {
  id         String   @id @default(cuid())
  userId     String
  sectorId   String?  // group chat context
  chatWithId String?  // private chat context (other user's id)
  updatedAt  DateTime @updatedAt

  sector Sector? @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectorId, userId])
  @@unique([chatWithId, userId])

  @@index([sectorId, userId])
  @@index([chatWithId, userId])
}

// User yang terkena blind
model BlindedMember {
  id       String   @id @default(cuid())
  sectorId String
  userId   String
  blindedAt DateTime @default(now())

  sector   Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user     User     @relation("BlindedUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectorId, userId])
}

// ============================================================
// OAUTH PROVIDER MODELS (SSO Orbit Station)
// ============================================================

/// Aplikasi pihak ketiga yang terdaftar untuk menggunakan SSO Orbit Station
model OAuthApp {
  id           String   @id @default(cuid())
  name         String
  clientId     String   @unique
  clientSecret String
  redirectUris String[] // Array URL callback yang sah
  homepageUrl  String?
  ownerId      String
  createdAt    DateTime @default(now())

  owner        User     @relation("OwnedApps", fields: [ownerId], references: [id], onDelete: Cascade)
}

/// Tiket sementara (Authorization Code) untuk proses pertukaran token
model OAuthCode {
  code        String   @id // Tiket/kode unik
  clientId    String
  userId      String
  redirectUri String
  expiresAt   DateTime // Hanya berlaku beberapa menit
  createdAt   DateTime @default(now())
}

/// Menyimpan data "Remember Consent" agar user tidak perlu klik Allow terus menerus
model OAuthConsent {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  createdAt DateTime @default(now())

  @@unique([userId, clientId])
}
